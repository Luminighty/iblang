extern putchar(c: char)

struct Vec2 {
	x: int,
	y: int,
}

struct Foo {
	c: *char,
	x: int,
	v: char,
}

struct Bar {
	foo: Foo,
	label: char,
}

struct Nested {
	v: Vec2,
	value: int,
}


// Prints Foo.v and Foo.x
fn print_foo(f: Foo) {
	putchar(f.v);
	putchar('0' + f.x);
}

fn test_pointer() {
	let a = 'x';
	let f = Foo {
		c: &a,
		x: 5,
		v: 'z',
	};
	*f.c = 'y'; // Mutate via pointer
	putchar(a); // Expect 'y'
}

// Test 2: Struct field mutation
fn test_field_mutation() {
	let v = Vec2 {
		x: 2,
		y: 9,
	};
	v.x = 4; // Mutate directly
	putchar('0' + v.x); // Expect '4'
	putchar('0' + v.y); // Expect '9'
}

// Test 3: Nested struct access
fn test_nested_struct() {
	let n = Nested {
		v: Vec2 {
			x: 7,
			y: 3,
		},
		value: 6,
	};
	putchar('0' + n.v.x); // Expect '7'
	putchar('0' + n.v.y); // Expect '3'
	putchar('0' + n.value); // Expect '6'
}

// Test 4: Struct inside struct
fn test_struct_in_struct() {
	let c = 'a';
	let b = Bar {
		foo: Foo {
			c: &c,
			x: 1,
			v: 'B',
		},
		label: 'Z',
	};
	// NOTE: Pass by value not implemented yet!
	// print_foo(b.foo); // Expect "B1"
	putchar(b.label); // Expect 'Z'
}

// Test 5: Passing struct to function
fn test_pass_struct() {
	let c = 'a';
	let f = Foo {
		c: &c,
		x: 8,
		v: 'Q',
	};
	print_foo(f); // Expect "Q8"
}

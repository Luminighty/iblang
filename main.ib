extern putchar(c: char)
extern printf(c: *char)

struct Vec2 { x: int, y: int }
struct Collider {
	enabled: bool,
	id: int,
}
struct Player {
	sprite: char,
	collider: Collider,
	position: Vec2,
}

let player = Player {
	sprite: 'o',
	position: Vec2 { x: 5, y: 3 },
	collider: Collider {
		id: 2,
		enabled: true
	}
};


extern fputc(c: char, stream: *int)
extern stderr: *int;
extern stdout: *int;

fn main(): int {
	fputc('c',stderr);
	fputc('x',stdout);
	return 1;
}


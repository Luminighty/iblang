	let f2 = Foo { c: &b, x: 0, v: 'B' };
	*f1.c = 'p';
	*f2.c = 'q';
	putchar(a); // Expect 'p'
	putchar(b); // Expect 'q'
}
*/

fn main(): int {
	test_pointer();        putchar('\n');
	test_field_mutation(); putchar('\n');
	test_nested_struct();  putchar('\n');
	test_struct_in_struct(); putchar('\n');
	// test_pass_struct();    putchar('\n');
	// test_pointer_swap();   putchar('\n');
	return 0;
}


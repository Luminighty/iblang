const std = import "@stdlib"

struct Vec2 { x: int, y: int }

fn main(): int {
	let v = Vec2{};
	std::printf("(%d, %d)\n", v.x, v.y);

	print_vecs(&v, 1);
	let vs = [Vec2{}, Vec2{x: 2, y: 3}, Vec2{}];
	print_vecs(vs, 3);

	return 0;
}

fn print_vecs(vecs: *Vec2, c: int) {
	for let i = 0; i < c; i+=1 {
		std::printf("%d => (%d, %d)\n", i, vecs[i].x, vecs[i].y);
	}
}

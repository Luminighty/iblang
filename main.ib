const stdio = import "./stdio"

enum Tile {
	AIR,	// 0
	STONE,	// 1
	GRASS,	// 2
	DIRT,	// 3
	IRON,	// 4
}

fn main(): int {
	let v = Tile::STONE;
	if v == Tile::STONE {
		stdio::println("Strike the Earth!");
	} else {
		stdio::println("Let the clowns loose!");
	}
	stdio::print_num(v);
	stdio::putchar('\n');
	return 0;
}


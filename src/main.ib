const stdlib = import "@stdlib"
const lexer = import "lexer/mod"
const utils = import "utils"
const strings = import "strings"


fn main(argc: int, argv: **char): int {
	strings::init();
	let result = lexer::run("./test.ib");
	if result != null {
		lexer::print_tokens(result);
		stdlib::printf("\n");
	}
	strings::free();
	return 0;
}


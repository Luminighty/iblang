const stdlib = import "@stdlib"
const utils = import "../utils.ib"
const node = import "./node.ib"


pub struct Cast {
	expr: int,
	type: int,
}


pub struct Array {
	elem_count: int,
	elems: int,
}


pub struct Call {
	callee: int,
	arg_count: int,
	args: *int,
}


// NOTE: Are we sure we need to use str for type?
pub struct ObjectInit {
	type: str,
	field_count: int,
	fields: *ObjectFieldInit,
}


pub struct ObjectFieldInit {
	value: int,
	key: str,
}


pub enum BinaryOp {
	Add, Sub,
	Mul, Div, Rem,

	Assign,
	AssignAdd, AssignSub,
	AssignMul, AssignDiv, AssignRem,

	EQ, NE,
	GT, GE,
	LT, LE,
	And, Or,

	Index,

	FieldLookup,
	Path,
}

pub struct Binary {
	op: BinaryOp,
	lhs: int,
	rhs: int,
}


pub enum UnaryOp {
	Group,
	Ref,
	Deref,
	Pos,
	Neg,
	Not,
}

pub struct Unary {
	op: UnaryOp,
	expr: int,
}


pub struct Literal {
	kind: LiteralKind,
	value: LiteralValue,
}


pub enum LiteralKind {
	Number,
	Float,
	String,
	Char,
	Bool,
	Null,
}


pub union LiteralValue {
	number: int,
	flt: float,
	string: str,
	chr: char,
	boolean: bool,
}


pub fn print_call(nodes: *node::Nodes, call: *Call, depth: int) {
	node::print(nodes, call.callee, depth);
	stdlib::putchar('(');
	for let i = 0; i < call.arg_count; i+=1 {
		node::print(nodes, call.args[i], depth);
		if i + 1 < call.arg_count {
			stdlib::printf(", ");
		}
	}
	stdlib::putchar(')');
}


pub fn print_unary(nodes: *node::Nodes, unary: *Unary, depth: int) {
	stdlib::putchar('(');
	match unary.op {
		UnaryOp::Group => {}
		UnaryOp::Ref => stdlib::printf("&"),
		UnaryOp::Deref => stdlib::printf("*"),
		UnaryOp::Pos => stdlib::printf("+"),
		UnaryOp::Neg => stdlib::printf("-"),
		UnaryOp::Not => stdlib::printf("!"),
	}
	node::print(nodes, unary.expr, depth);
	stdlib::putchar(')');
}


pub fn print_binary(nodes: *node::Nodes, binary: *Binary, depth: int) {
	stdlib::putchar('(');
	node::print(nodes, binary.lhs, depth);
	match binary.op {
		BinaryOp::Add => stdlib::printf("+"),
		BinaryOp::Sub => stdlib::printf("-"),
		BinaryOp::Mul => stdlib::printf("*"),
		BinaryOp::Div => stdlib::printf("/"),
		BinaryOp::Rem => stdlib::printf("%"),
		BinaryOp::Assign => stdlib::printf("="),
		BinaryOp::AssignAdd => stdlib::printf("+="),
		BinaryOp::AssignSub => stdlib::printf("-="),
		BinaryOp::AssignMul => stdlib::printf("*="),
		BinaryOp::AssignDiv => stdlib::printf("/="),
		BinaryOp::AssignRem => stdlib::printf("%="),
		BinaryOp::EQ => stdlib::printf("=="),
		BinaryOp::NE => stdlib::printf("!="),
		BinaryOp::GT => stdlib::printf(">"),
		BinaryOp::GE => stdlib::printf(">="),
		BinaryOp::LT => stdlib::printf("<"),
		BinaryOp::LE => stdlib::printf("<="),
		BinaryOp::And => stdlib::printf("&&"),
		BinaryOp::Or => stdlib::printf("||"),
		BinaryOp::Index => stdlib::printf("["),
		BinaryOp::FieldLookup => stdlib::printf("."),
		BinaryOp::Path => stdlib::printf("::"),
	}
	node::print(nodes, binary.rhs, depth);
	match binary.op {
		BinaryOp::Index => stdlib::printf("]"),
		_ => {}
	}
	stdlib::putchar(')');
}


pub fn print_literal(literal: *Literal, depth: int) {
	match literal.kind {
		LiteralKind::Number => stdlib::printf("%d", literal.value.number),
		LiteralKind::Float => stdlib::printf("%f", literal.value.flt),
		LiteralKind::String => {
			utils::debug_str(literal.value.string);
		}
		LiteralKind::Char => {
			utils::debug_char(literal.value.chr);
		}
		LiteralKind::Bool => {
			if literal.value.boolean {
				stdlib::printf("true");
			} else { 
				stdlib::printf("false");
			}
		}
		LiteralKind::Null => stdlib::printf("null"),
	}
}


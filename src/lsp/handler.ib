	// "method":"textDocument/hover","jsonrpc":"2.0"}

fn on_document_hover(
	context: *context::Context,
	req: *request::Request,
	res: *response::Builder
): Status {
	stdlib::fprintf(context.log, "[DEBUG] on_document_hover\n");

	let doc = json::lookup(req.params, "textDocument");
	let uri = json::lookup(doc, "uri");
	let uri_len = json::length(uri);
	let uri = json::as_str(uri);

	let position = json::lookup(req.params, "position");
	let line = json::as_number(json::lookup(position, "line"));
	let col = json::as_number(json::lookup(position, "character"));

	let file = file::find(&context.files, uri, uri_len);

	let position = "                                             ";
	stdlib::sprintf(position, "  Position: %d:%d", line, col);

	response::begin(res);
	response::id(res, req.id);
	response::sep(res);

	response::begin_result(res);
		response::key(res, "contents");
		response::begin_array(res);
		response::string(res, " Hello from ib! :)  ");
		response::sep(res);
		response::string(res, position);
		response::end_array(res);
	response::end_result(res);
	response::end(res);

	response::send(res);
	return Status::Ok;
}

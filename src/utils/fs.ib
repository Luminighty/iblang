const stdlib = import "@stdlib"

pub struct File {
	success: bool,
	length: int,
	content: *char,
}

pub fn read_file(file: *char): File {
	let result = File {
		success: false,
		length: 0,
		content: null
	};
	let file = stdlib::fopen(file, "r");
	if file == null { return result; }

	stdlib::fseek(file, 0, stdlib::FileSeek::End);
	let size = stdlib::ftell(file);
	stdlib::fseek(file, 0, stdlib::FileSeek::Start);

	let buffer: *char = stdlib::malloc(size + 1);

	stdlib::fread(buffer, 1, size, file);
	buffer[size] = '\0';
	stdlib::fclose(file);

	result.content = buffer;
	result.length = size;
	result.success = true;
	return result;
}


pub fn write_file(file: str, content: str): bool {
	let file = stdlib::fopen(file, "w");
	if file == null { return false; }


	// TODO: Probably validate if all of it has been sent
	stdlib::fputs(content, file);

	stdlib::fclose(file);
	return true;
}


pub fn free(file: *File) {
	file.success = false;
	file.length = 0;
	stdlib::free(file.content);
}


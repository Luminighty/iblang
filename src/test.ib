const storage = import "./storage/mod.ib"

const tests = import "./tests/mod.ib"

const stdlib = import "@stdlib"
const color = import "./utils/color.ib"

// NOTE: ib -e --entry=./src/test

fn main(argc: int, argv: *str): int {
	storage::init();

	let res = tests::run_all_tests();

	storage::free();
	return res;
}


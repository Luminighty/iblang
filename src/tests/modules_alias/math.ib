import "./stdio"

extern putchar(c: char)

pub struct Vec2 {
	x: int,
	y: int,
}

pub fn vec2_create(x: int, y: int): Vec2 {
	return Vec2 { x: x, y: y, };
}

pub fn vec2_add(a: Vec2, b: Vec2): Vec2 {
	let x = a.x + b.x;
	let y = a.y + b.y;
	return Vec2 { x: x, y: y, };
}

pub fn vec2_print(vec: *Vec2) {
	print("Vec2{x:");
	print_num(vec.x);
	print(";y:");
	print_num(vec.y);
	putchar('}');
}


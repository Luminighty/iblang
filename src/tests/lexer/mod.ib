const stdlib = import "@stdlib"

const snapshot = import "../snapshot.ib"
const sb = import "../../utils/stringbuilder.ib"
const fs = import "../../utils/fs.ib"
const lexer = import "../../lexer/mod.ib"
const errors = import "../../storage/error.ib"


let PASS = true;

pub fn run_tests() {
	snapshot::base_path("./src/tests/lexer/");

	lexer_test("keywords.ib");
	lexer_test("literal.ib");
	lexer_test("symbols.ib");

	stdlib::assert(PASS, "Snapshots failed.");
}


let sb = sb::StringBuilder {};
fn lexer_test(source: str) {
	sb::reset(&sb);

	let errors = errors::new();
	let filename = snapshot::file_source(source);
	let file = fs::read_file(filename);

	let result = lexer::run(filename, file.content, file.length, &errors);
	if result.success {
		lexer::write_tokens(&sb, &result.tokens);
	} else {
		errors::write_errors(&sb, &errors, false);
	}
	lexer::free(&result.tokens);
	errors::free(&errors);

	let snapshot = sb::merge(&sb);
	let result = snapshot::test(source, snapshot);
	if !result.success { PASS = false; }
}


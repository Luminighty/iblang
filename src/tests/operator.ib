extern putchar(val: char)

fn main(): int {
  let a = 5;
  let b = 3;
  putchar('0' + (a + b)); // 8
  putchar('0' + (a - b)); // 2
  a = 2;
  putchar('0' + (a * b)); // 6
  a = 6;
  putchar('0' + (a / b)); // 2
  a = 4;
  putchar('0' + (a % b)); // 1

  if a == b { putchar('='); } //
  if a != b { putchar('!'); } // !
  if a > b { putchar('>'); } // >
  if a < b { putchar('<'); } //
  if a >= b { putchar('>'); } // >
  if a <= b { putchar('<'); } //
  if a <= b || a >= b { putchar('|'); } // |
  if a <= b && a >= b { putchar('&'); } //

  let a = 263;
  let b = -13;
  if 263 == +a { putchar('+'); } 	// +
  if -263 == -a { putchar('-'); } 	// -
  if -13 == +b { putchar('b'); } 	// b
  if 13 == -b { putchar('-'); }		// -
  let b = true;
  let a = false;
  if b { putchar('B'); }		// B
  if !b == false { putchar('b'); }	// b
  if !a { putchar('A'); }		// A

  let a = 10;
  if (a - 5) * (3 + 7) / 2 == 25 { putchar('O'); } // O
  return 0;
}

extern putchar(c: char)

struct VecXY {
	x: int,
	y: int,
}

union Vec2 {
	i: int[2],
	v: VecXY,
}

union Number {
	i: int,
	f: float,
}

struct Ray {
	origin: Vec2,
	delta: Vec2,
}

fn print_vec2_i(v: Vec2) {
	putchar('(');
	putchar('0' + v.i[0]);
	putchar(',');
	putchar('0' + v.i[1]);
	putchar(')');
}

fn print_vec2_v(v: Vec2) {
	putchar('(');
	putchar('0' + v.v.x);
	putchar(',');
	putchar('0' + v.v.y);
	putchar(')');
}

fn create_vec_i(x: int, y: int): Vec2 {
	return Vec2 { i: [x, y] };
}
fn create_vec_v(x: int, y: int): Vec2 {
	return Vec2 { v: VecXY { x, y } };
}

// Tests

fn test_union_basic() {
	let a = create_vec_i(1, 2);
	let b = create_vec_v(3, 4);
	print_vec2_i(a);	// (1,2)
	print_vec2_v(a);	// (1,2)
	print_vec2_i(b);	// (3,4)
	print_vec2_v(b);	// (3,4)
	putchar('\n');
}

fn test_union_aliasing() {
	let v = create_vec_i(5, 6);
	print_vec2_i(v);	// (5,6)
	v.v.x = 8;
	print_vec2_i(v);	// (8,6)
	v.i[1] = 9;
	print_vec2_v(v);	// (8,9)
	putchar('\n');
}

fn test_union_access() {
	let v = create_vec_v(2, 7);
	putchar('0' + v.i[0]); // 2
	putchar('0' + v.i[1]); // 7
	putchar('0' + v.v.x);  // 2
	putchar('0' + v.v.y);  // 7
	putchar('\n');
}

fn mutate_union(v: Vec2): Vec2 {
	v.i[0] = v.i[0] + 1;
	v.i[1] = v.i[1] + 2;
	return v;
}
fn test_union_pass_value() {
	let v = create_vec_i(1, 3);
	let r = mutate_union(v);
	print_vec2_i(v); // (1,3)
	print_vec2_i(r); // (2,5)
	putchar('\n');
}

fn mutate_union_ptr(v: *Vec2) {
	(*v).v.x = (*v).v.x + 4;
	(*v).v.y = (*v).v.y + 1;
}
fn test_union_pass_pointer() {
	let v = create_vec_v(2, 3);
	print_vec2_v(v); // (2,3)
	mutate_union_ptr(&v);
	print_vec2_v(v); // (6,4)
	putchar('\n');
}

fn print_ray(ray: Ray) {
	print_vec2_v(ray.origin);
	putchar('-');
	putchar('>');
	let target = Vec2 { i: [
		ray.origin.v.x + ray.delta.v.x,
		ray.origin.v.y + ray.delta.v.y
	]};
	print_vec2_v(target);
}

fn test_union_in_struct() {
	let r = Ray {
		origin: create_vec_i(1, 2),
		delta: create_vec_v(3, 4),
	};
	print_ray(r); // (1,2)->(4,6)
	putchar('\n');
}

fn test_union_assignment() {
	let a = create_vec_v(5, 5);
	let b = create_vec_i(1, 9);
	print_vec2_v(a); // (5,5)
	print_vec2_i(b); // (1,9)
	putchar(' ');
	let c = a;
	a.v.x = 7;
	a.v.y = 8;
	print_vec2_v(a); // (7,8)
	print_vec2_v(c); // (5,5)
	putchar('\n');
}

fn test_union_array() {
	let arr = [ create_vec_i(1, 2), create_vec_v(3, 4), create_vec_i(5, 6) ];
	print_vec2_i(arr[0]);
	print_vec2_i(arr[1]);
	print_vec2_i(arr[2]);
	putchar(' ');
	arr[1].v.x = 9;
	arr[1].v.y = 8;
	print_vec2_v(arr[1]); // (9,8)
	putchar('\n');
}

fn return_union(cond: bool): Vec2 {
	if cond {
		return Vec2 { i: [1, 1] };
	} else {
		return Vec2 { v: VecXY { x: 9, y: 9 } };
	}
}
fn test_union_return() {
	print_vec2_i(return_union(true));  // (1,1)
	print_vec2_v(return_union(false)); // (9,9)
	putchar('\n');
}

fn zero_vec(v: *Vec2) {
	(*v).i[0] = 0;
	(*v).i[1] = 0;
}
fn test_union_pointer_alias() {
	let v = create_vec_v(4, 5);
	print_vec2_v(v); // (4,5)
	zero_vec(&v);
	print_vec2_v(v); // (0,0)
	putchar('\n');
}

fn test_union_numeric() {
	let n = Number { i: 42 };
	putchar('N');
	putchar('0' + (n.i / 10)); // '4'
	putchar('0' + (n.i % 10)); // '2'
}


fn main(): int {
	test_union_basic();
	test_union_aliasing();
	test_union_access();
	test_union_pass_value();
	test_union_pass_pointer();
	test_union_in_struct();
	test_union_assignment();
	test_union_array();
	test_union_return();
	test_union_pointer_alias();
	test_union_numeric();
	return 0;
}

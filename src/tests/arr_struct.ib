extern putchar(c: char)

struct Foo {
	c: *char,
	x: int,
	v: char,
}

struct Message {
	msg: char[19],
	ip: int[4],
}

fn print_foo(foo: Foo) {
	putchar(*foo.c);
	putchar('0' + foo.x);
	putchar(foo.v);
}

fn test_array_of_structs() {
	let a = 'a';
	let b = 'b';
	let c = 'c';
	let arr = [
		Foo { c: &a, x: 2, v: 'i', },
		Foo { c: &b, x: 4, v: 'j', },
		Foo { c: &c, x: 6, v: 'k', },
	];
	print_foo(arr[0]);	// a2i
	print_foo(arr[1]);	// b4j
	print_foo(arr[2]);	// c6k
	arr[1].c = &a;
	arr[1].x = 5;
	print_foo(arr[1]);	// a5j
}

fn send_message(message: Message) {
	putchar('0' + message.ip[0]); putchar('.');
	putchar('0' + message.ip[1]); putchar('.');
	putchar('0' + message.ip[2]); putchar('.');
	putchar('0' + message.ip[3]);
	putchar(':');
	putchar(' ');
	let i = 0;
	while message.msg[i] != '\0' {
		putchar(message.msg[i]);
		i = i + 1;
	}
}

fn test_struct_of_arrays() {
	let message = Message {
		msg: "What the dog doin?",
		ip: [8, 3, 3, 1]
	};
	send_message(message);	// 8.3.3.1: What the dog doin?
}

fn main(): int {
	test_array_of_structs(); putchar('\n');
	test_struct_of_arrays(); putchar('\n');
	return 0;
}


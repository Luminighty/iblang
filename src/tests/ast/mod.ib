const stdlib = import "@stdlib"
const build = import "../../build.ib"
const ast = import "../../ast/mod.ib"
const fs = import "../../utils/fs.ib"
const sb = import "../../utils/stringbuilder.ib"

let PASS = true;

pub fn run_tests() {
	snapshot_test("test_hello.ib");
	snapshot_test("test_basic.ib");
	snapshot_test("test_enum.ib");

	snapshot_test("test_arith.ib");
	snapshot_test("test_global.ib");

	snapshot_test("test_objects.ib");

	snapshot_test("test_fn_ptrs.ib");
	snapshot_test("test_pointers.ib");
	snapshot_test("test_sizeof.ib");
	snapshot_test("test_array.ib");

	stdlib::assert(PASS, "Snapshots failed.");
}


let sb = sb::StringBuilder{};
fn snapshot_test(source: str) {

	let builder = build::new();
	let result = build::parse_file(snapshot_file_source(source), &builder);
	if !result.success {
		stdlib::fprintf(stdlib::stderr, "Failed to parse %s\n", snapshot_file_source(source));
		PASS = false;
		return;

	}

	sb::reset(&sb);
	ast::debug_module(&sb, result.module);
	ast::free_module(result.module, false);

	let snapshot = sb::build(&sb);
	let expected = fs::read_file(snapshot_file_expected(source));
	let result = snapshot_compare(expected.content, snapshot);

	if !result.success {
		snapshot_fail(&result, source, snapshot);
		PASS = false;
	}
	stdlib::free(snapshot);

	// let file = stdlib::fopen(snapshot_file, "r");
}


let sb_files = sb::StringBuilder{};
let base_path = "./src/tests/ast/";
fn snapshot_file_source(filename: str): str {
	sb::reset(&sb_files);
	sb::append(&sb_files, base_path);
	sb::append(&sb_files, filename);
	return sb::merge(&sb_files);
}
fn snapshot_file_expected(filename: str): str {
	sb::reset(&sb_files);
	sb::append(&sb_files, base_path);
	sb::append(&sb_files, "snapshot/");
	sb::append(&sb_files, filename);
	sb::append(&sb_files, ".snap");
	return sb::merge(&sb_files);
}
fn snapshot_file_result(filename: str): str {
	sb::reset(&sb_files);
	sb::append(&sb_files, base_path);
	sb::append(&sb_files, "snapshot/");
	sb::append(&sb_files, filename);
	sb::append(&sb_files, ".snap.actual");
	return sb::merge(&sb_files);
}


fn snapshot_fail(result: *SnapshotResult, filename: str, got: str) {
	stdlib::fprintf(stdlib::stderr, "Snapshot test failed \"%s\"\n", snapshot_file_source(filename));
	stdlib::fprintf(stdlib::stderr, "\tdiff %s ", snapshot_file_expected(filename));
	stdlib::fprintf(stdlib::stderr, "%s\n", snapshot_file_result(filename));

	fs::write_file(snapshot_file_result(filename), got);
}


struct SnapshotResult {
	success: bool,
}
fn snapshot_compare(expected: str, got: str): SnapshotResult {
	let result = SnapshotResult { success: false };
	if (expected == null) != (got == null) { return result; }
	result.success = stdlib::strcmp(expected, got) == 0;
	return result;
}

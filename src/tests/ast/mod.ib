const stdlib = import "@stdlib"

const snapshot = import "../snapshot.ib"
const build = import "../../build.ib"
const ast = import "../../ast/mod.ib"
const sb = import "../../utils/stringbuilder.ib"
const err = import "../../storage/error.ib"

let PASS = true;

pub fn run_tests() {
	snapshot::base_path("./src/tests/ast/");

	ast_test("test_hello.ib");
	ast_test("test_basic.ib");
	ast_test("test_enum.ib");

	ast_test("test_arith.ib");
	ast_test("test_global.ib");

	ast_test("test_objects.ib");

	ast_test("test_fn_ptrs.ib");
	ast_test("test_pointers.ib");
	ast_test("test_sizeof.ib");
	ast_test("test_array.ib");

	ast_test("test_errors_declaration.ib");
	ast_test("test_errors_enum.ib");
	ast_test("test_errors_object.ib");
	ast_test("test_errors_prototypes.ib");

	stdlib::assert(PASS, "Snapshots failed.");
}


let sb = sb::StringBuilder{};
fn ast_test(source: str) {
	sb::reset(&sb);

	let builder = build::new();
	let result = build::parse_file(snapshot::file_source(source), &builder);
	if result.success {
		ast::debug_module(&sb, result.module);
	} else {
		err::write_errors(&sb, &builder.errors, false);
	}
	if result.module != null {
		ast::free_module(result.module, false);
	}

	let snapshot = sb::merge(&sb);
	let result = snapshot::test(source, snapshot);
	if !result.success {
		PASS = false;
	}
}


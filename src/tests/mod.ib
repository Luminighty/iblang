const stdlib = import "@stdlib"

const runner = import "./runner.ib"
const lexer = import "./lexer/mod.ib"
const ast = import "./ast/mod.ib"
const ident = import "./identifiers.ib"


pub fn run_all_tests(): int {
	runner::setup();
	
	runner::test(lexer::run_tests, "lexer");
	runner::test(ident::run_tests, "ident");
	runner::test(ast::run_tests, "ast");

	return runner::finish();
}


pub fn fail(): ! {
	stdlib::fflush(stdlib::stdout);
	stdlib::fflush(stdlib::stderr);
	stdlib::exit(1);
}


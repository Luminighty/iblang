extern putchar(c: char)

struct Vec2 {
	x: int,
	y: int,
}

struct Foo {
	c: *char,
	x: int,
	v: char,
}

struct Bar {
	foo: Foo,
	label: char,
}

struct Nested {
	v: Vec2,
	value: int,
}


// Prints Foo.v and Foo.x
fn print_foo(f: Foo) {
	putchar(f.v);
	putchar('0' + f.x);
}

fn test_pointer() {
	let a = 'x';
	let f = Foo {
		c: &a,
		x: 5,
		v: 'z',
	};
	*f.c = 'y'; // Mutate via pointer
	putchar(a); // Expect 'y'
}

// Test 2: Struct field mutation
fn test_field_mutation() {
	let v = Vec2 {
		x: 2,
		y: 9,
	};
	v.x = 4; // Mutate directly
	putchar('0' + v.x); // Expect '4'
	putchar('0' + v.y); // Expect '9'
}

// Test 3: Nested struct access
fn test_nested_struct() {
	let n = Nested {
		v: Vec2 {
			x: 7,
			y: 3,
		},
		value: 6,
	};
	putchar('0' + n.v.x); // Expect '7'
	putchar('0' + n.v.y); // Expect '3'
	putchar('0' + n.value); // Expect '6'
}

// Test 4: Struct inside struct
fn test_struct_in_struct() {
	let c = 'a';
	let b = Bar {
		foo: Foo {
			c: &c,
			x: 1,
			v: 'B',
		},
		label: 'Z',
	};
	// NOTE: Pass by value not implemented yet!
	print_foo(b.foo); // Expect "B1"
	putchar(b.label); // Expect 'Z'
}

// Test 5: Passing struct to function
fn test_pass_struct() {
	let c = 'a';
	let f = Foo {
		c: &c,
		x: 8,
		v: 'Q',
	};
	print_foo(f); // Expect "Q8"
}

// Test 6: Pointer field swap
fn test_pointer_swap() {
	let a = 'm';
	let b = 'n';
	let f1 = Foo { c: &a, x: 0, v: 'A' };
	let f2 = Foo { c: &b, x: 0, v: 'B' };
	*f1.c = 'p';
	*f2.c = 'q';
	putchar(a); // Expect 'p'
	putchar(b); // Expect 'q'
}


// Test 7: Pass structs by pointers
fn set_foo_x(foo: *Foo) {
	(*foo).x = 8;
}

fn set_foo_v(foo: *Foo, new_char: char) {
	(*foo).v = new_char;

}

fn test_pass_struct_pointer() {
	let c = 'a';
	let f = Foo {
		c: &c,
		x: 2,
		v: 'Q',
	};
	print_foo(f);	// Q2
	set_foo_x(&f);
	set_foo_v(&f, 'B');
	print_foo(f);	// B8
}


fn test_struct_assignment() {
	let c = 'c';
	let f = Foo {
		c: &c,
		x: 3,
		v: 'B',
	};
	let g = f;
	f.x = 5;
	f.v = 'F';
	print_foo(g);	// B3
	print_foo(f);	// F5
	putchar(*g.c);	// c
	putchar(*f.c);	// c
	*g.c = 'x';
	putchar(c);	// x
	putchar(*g.c);	// x
	putchar(*f.c);	// x
}

fn create_vec2(x: int, y: int): Vec2 {
	return Vec2 {x: x, y: y};
}

fn return_branched(v: bool): Vec2 {
	if v {
		return Vec2 {x: 3, y: 3};
	} else {
		return Vec2 {x: 5, y: 6};
	}
}

fn create_nested(v: Vec2, value: int): Nested {
	return Nested { v: v, value: value, };
}

fn print_vec(vec: Vec2) {
	putchar('(');
	putchar('0' + vec.x);
	putchar(',');
	putchar('0' + vec.y);
	putchar(')');
}

fn test_struct_return_value() {
	let a = create_vec2(5, 3);
	let b = create_vec2(2, 1);
	a.x = 4;
	print_vec(a);			// (4,3)
	print_vec(b);			// (2,1)
	print_vec(create_vec2(8, 9));	// (8,9)

	let nested = create_nested(create_vec2(1,1), 4);
	print_vec(nested.v);		// (1,1)
	putchar('0' + nested.value);	// 4
	print_vec(return_branched(true));// (3,3)
	print_vec(return_branched(false));// (5,6)
}

fn test_struct_reassign() {
	let a = create_vec2(5, 3);
	let b = create_vec2(2, 1);
	print_vec(a);	// (5,3)
	print_vec(b);	// (2,1)
	a = create_vec2(9, 8);
	b = Vec2 { x: 1, y: 4 };
	print_vec(a);	// (9,8)
	print_vec(b);	// (1,4)
}

fn main(): int {
	test_pointer();        putchar('\n');
	test_field_mutation(); putchar('\n');
	test_nested_struct();  putchar('\n');
	test_struct_in_struct(); putchar('\n');
	test_pass_struct();    putchar('\n');
	test_pointer_swap();   putchar('\n');
	test_pass_struct_pointer();   putchar('\n');
	test_struct_assignment(); putchar('\n');
	test_struct_return_value(); putchar('\n');
	test_struct_reassign(); putchar('\n');
	return 0;
}


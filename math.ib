import "./utils"

extern putchar(c: char)
extern print(msg: *char)
extern print_num(num: int)

struct Vec2 {
	x: int,
	y: int,
}

pub fn vec2_create(x: int, y: int): Vec2 {
	return Vec2 { x: x, y: y, };
}

pub fn vec2_print(vec: *Vec2) {
	print("Vec2{x:");
	print_num(vec.x);
	print(";y:");
	print_num(vec.y);
	print("}");
}

extern putchar(c: char)
extern printf(c: *char): void


pub fn print(msg: *char) {
	for let i = 0; msg[i] != '\0'; i = i + 1 {
		putchar(msg[i]);
	}
}

pub fn println(msg: *char) {
	print(msg);
	putchar('\0');
}

pub fn print_num(num: int) {
	let inner = val / 10;
	if inner > 0 {
		print_num(inner);
	}
	putchar('0' + val % 10);
}


const utils = import "utils"
const strings = import "./strings"
const idents = import "./identifiers"
const tests = import "./tests/mod"
const span = import "./storage/span"

import "./symbol/mod.ib"

const PRINT_LEXER = false;

const RUN_TEST = false;
let had_errors = false;

pub extern getchar(): int
pub extern scanf(format: *char, ...)

pub extern stdout: *any;
pub extern stderr: *any;

struct test { abc: int }
union test2 { abc: int }


fn main(argc: int, argv: **char): int {

	// 1. Path, Field, Call, and Indexing (The "Left-Hand Side" chain)
	// Goal: (((std::buffer)[i]).data).offset(1)
	let a = std::buffer[i].data.offset(1);

	// 2. Prefix vs. Accessors
	// Goal: *(ptr.map[i]) -- Index/Dot (100+) should beat Deref (90)
	let b = *ptr.map[i];

	// 3. Cast vs. Arithmetic and Prefix
	// Goal: (*(ptr as *u64)) + 1 -- Based on your As (70) and Deref (90)
	// NOTE: Check if you want (ptr as *u64) or (*ptr) as u64!
	let c = *ptr as *u64 + 1;

	// 4. The "C-Mistake" Fix (Bitwise vs. Comparison)
	// Goal: ((status & mask) == target) -- BitAnd (35) should beat EqEq (20)
	let d = status & mask == target;

	// 5. Shift vs. Additive
	// Goal: (x << (y + z)) -- Add (50) should beat Shift (40)
	let e = x << y + z;

	// 6. Logical Chain (And vs. Or)
	// Goal: (a || (b && (c == d))) -- And (12) should beat Or (10)
	let f = a || b && c == d;

	// 7. Bitwise Stack
	// Goal: (a | (b ^ (c & d))) -- & (35) > ^ (32) > | (30)
	let g = a | b ^ c & d;

	// 8. Right-Associative Assignment
	// Goal: (x = (y = (z = 10)))
	let h = x = y = z = 10;

	// 9. Assignment with Logic
	// Goal: (is_valid = (val > 0 && ready)) -- Logic (12/10) should beat Assign (2)
	let i = is_valid = val > 0 && ready;

	// 10. The Kitchen Sink
	// Goal: (*((obj.items)[i].ptr) = ((val << 1) + (offset as i32)))
	let j = *obj.items[i].ptr = val << 1 + offset as i32;

	// 1. Deref then Cast
	// Expected: ((*ptr) as u64)
	let a = *ptr as u32;

	// 2. Ref then Cast
	// Expected: ((&val) as *void)
	let b = &val as *u32;

	// 3. Double Prefix then Cast
	// Expected: ((**ptr_ptr) as u64)
	// let c = **ptr_ptr as u64;

	// 4. Casting the result of an Offset
	// Expected: (((ptr + 1) as *u64))
	// (Since + is 50 and As is 70)
	let d = ptr + 1 as *u32;

	// 5. The "Rust Style" Challenge (Cast the pointer before deref)
	// Expected: (*(ptr as *vec))
	// NOTE: With your current 90 vs 70, this will parse as ((*ptr) as *u64)
	// and likely throw a compiler error because you can't cast the result of 
	// a deref to a pointer. You would need parens.
	let e = *ptr as *u32;

	a = b = c[i][j] = *ptr;
	let val = *std::math::Constants.pi_ptr;
	let res = 10 + get_data(id) as float * 2.5;
	*buffer[i].data = val + 1 > 10 && ready::now();

	let abc = *foo as *bar;

	let foo = 123 >> 321;

	init();
	if RUN_TEST { run_tests(); }

	parse_file("./test.ib");

	let v = test::with::me { asdf: 123 };

	let a = v as *any;


	symbol::debug();

	let other = what::iif::this.is.a.long;
	let call = what::iif::this.is.a.call(123, 325);

	for let a = 123; a > 123; a=1 {
		stdlib::printf("hello ali");
	}

	cleanup();
	let v: vec::From::Vector::ABC::Gro::help::amogus = 123;

	if had_errors { return 1; }
	return 0;
}


pub enum TokenKind {
	None,

	ParenL, ParenR = 123,
	BraceL, BraceR = "aaaaaaaaaaa",

	Comma, Colon, ColonColon = 2 + 4 * PRINT_LEXER,
	Dot, DotDotDot, SemiColon,
}

fn main(argc: int, argv: **char) {
	init();
	if RUN_TEST { run_tests(); }

	parse_file("./test.ib");

	symbol::debug();

	cleanup();

	if had_errors { return 1; }
	return 0;
}


pub fn parse_file(filename: str) {
	let result = lexer::run(filename);
	if !result.success { had_errors = true; return; }
	if PRINT_LEXER {
		lexer::print_tokens(&result.tokens);
		stdlib::printf("\n");
	}

	ast::run(filename, result.tokens);
}

// ===========================
// ========== UTILS ==========
// ===========================

fn init() {
	strings::init();
	symbol::init();
	ast::init();
}


fn cleanup() {
	ast::free();
	symbol::free();
	idents::free();
	strings::free();
}


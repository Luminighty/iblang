fn main(argc: int, argv: **char): int {
	init();
	if RUN_TEST { run_tests(); }

	parse_file("./test.ib");

	let v = test::with::me { asdf: 123 };
	let v = [123, 32, printf("asd"), [3, 6, 2]]

	let a = v as *any;


	symbol::debug();

	for let a = 123; a > 123; a=1 {
		stdlib::printf("hello ali");
	}

	cleanup();
	let v = sizeof(*vec::From::Vector);
	let v: vec::From::Vector::ABC::Gro::help::amogus = 123;

	if had_errors { return 1; }
	return 0;
}


pub enum TokenKind {
	None,

	ParenL, ParenR = 123,
	BraceL, BraceR = "aaaaaaaaaaa",

	Comma, Colon, ColonColon = 2 + 4 * PRINT_LEXER,
	Dot, DotDotDot, SemiColon,
}

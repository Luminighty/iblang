extern putchar(c: char)


fn main(): int {
  putchar('('); // (
  putchar('0' + fib(6)); // 8
  putchar(')'); // )

  return 0;
}

fn fib(n: int): int {
  putchar('f');
  putchar('i');
  putchar('b');
  putchar('(');
  putchar('0' + n);
  putchar(')');
  putchar('\n');
  if n <= 2 {
    return 1;
  } else {
    return fib(n - 1) + fib(n - 2);
  }
}


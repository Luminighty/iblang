extern putchar(val: char)

struct Foo {
  bar: int,
  baz: char,
}

struct Test {
  name: char,
  bar: char,
  foo: Foo,
}

fn cprint(s: *char) {
  let i = 0;
  while s[i] != '\0' {
    putchar(s[i]);
    i = i + 1;
  }
}

fn test(t: *Test) {
  (*t).bar = 'O';
}

fn main() {
  let foo = Test {
    foo: Foo {
      bar: 123,
      baz: 'G'
    },
    name: 'c',
    bar: 'b',
  };
  foo.bar = 'A';
  test(&foo);
  //putchar(foo.foo.baz);
  putchar('\n');
  let b = "hello ali!\n";
  cprint(b);
}


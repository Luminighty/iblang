extern putchar(val: char)

struct Bar {
  baz: char,
}

struct Foo {
  bar: Bar,
  baz: char,
}

struct Test {
  name: char,
  foo: Foo,
}

struct Vec2 {
  x: int,
  y: int,
}

struct Other {
  msg: char[6],
}

fn main() {
  /*

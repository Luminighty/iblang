  putchar('0' + test[1].y);
  */

  let v = Other {
    msg: "test\n"
  };
  cprint(v.msg);
  struct_test_ref(&v);
  cprint(v.msg);
}

fn struct_test(other: Other) {
  other.msg[0] = 'V';
  cprint(other.msg);
}

fn struct_test_ref(other: *Other) {
  (*other).msg[0] = 'V';
}

fn cprint(s: *char) {
  let i = 0;
  while s[i] != '\0' {
    putchar(s[i]);
    i = i + 1;
  }
}


extern putchar(val: char)

struct Foo {
  bar: int,
  baz: float,
  b: bool,
  test: int,
}

struct Test {
  name: char,
  foo: Foo,
  bar: char,
}

fn cprint(s: *char) {
  let i = 0;
  while s[i] != '\0' {
    putchar(s[i]);
    i = i + 1;
  }
}

fn main() {
  let foo = Test {
    foo: 234,
    name: 'c',
  };
  let b = "hello ali!\n";
  cprint(b);
}

